{
  "name": "@ansvar/austrian-law-mcp",
  "mcpName": "eu.ansvar/austrian-law-mcp",
  "version": "1.0.3",
  "description": "Austrian Law MCP \u2014 German legislation via Model Context Protocol",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "austria-law-mcp": "dist/index.js"
  },
  "files": [
    "dist",
    "data/database.db"
  ],
  "scripts": {
    "build": "tsc",
    "build:db": "node --import tsx scripts/build-db.ts",
    "dev": "node --import tsx src/index.ts",
    "start": "node dist/index.js",
    "pretest": "bash scripts/download-db.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "pretest:coverage": "bash scripts/download-db.sh",
    "test:coverage": "vitest run --coverage",
    "db:update-seed": "node --import tsx scripts/update-db-from-seed.ts",
    "pretest:contract": "bash scripts/download-db.sh",
    "test:contract": "vitest run __tests__/contract/",
    "validate": "npm test && npm run test:contract",
    "prepublishOnly": "npm run build",
    "postinstall": "test -d dist || npm run build || true",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ansvar/mcp-sqlite": "^1.0.3",
    "@modelcontextprotocol/sdk": "^1.25.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.29",
    "@vitest/coverage-v8": "^4.0.18",
    "better-sqlite3": "^12.6.2",
    "fast-xml-parser": "^5.3.5",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Ansvar-Systems/Austrian-law-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Ansvar-Systems/Austria-law-mcp/issues"
  },
  "homepage": "https://github.com/Ansvar-Systems/Austria-law-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "ai",
    "claude",
    "at-law",
    "austria",
    "legal",
    "compliance",
    "ris-ogd",
    "ansvar"
  ],
  "author": "Ansvar Systems AB <hello@ansvar.ai>",
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  }
}
